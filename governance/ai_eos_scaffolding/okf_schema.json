{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OpenKnowledgeFormatMetadata",
  "description": "JSON Schema for validating OKF metadata blocks in markdown frontmatter.",
  "type": "object",
  "required": [
    "okf_version",
    "domain",
    "id",
    "title",
    "owner",
    "last_updated",
    "status",
    "dependencies",
    "relations"
  ],
  "properties": {
    "okf_version": {
      "type": "string",
      "enum": ["1.0.0", "1.1.0", "2.0.0"]
    },
    "domain": {
      "type": "string",
      "enum": [
        "business",
        "product",
        "architecture",
        "engineering",
        "security",
        "operations",
        "data",
        "compliance",
        "runbooks",
        "incidents",
        "metrics",
        "glossary"
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "title": {
      "type": "string"
    },
    "owner": {
      "type": "object",
      "required": ["role", "contact"],
      "properties": {
        "role": { "type": "string" },
        "contact": { "type": "string", "format": "email" }
      }
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "proposed", "active", "deprecated", "archived"]
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "description": "IDs of other OKF files or specs this file depends on"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target_id"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["implements", "extends", "supersedes", "documents", "references"]
          },
          "target_id": {
            "type": "string"
          }
        }
      }
    },
    "retrieval_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
