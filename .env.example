# ============================================================
# UAWOS Environment Configuration
# ============================================================
# Copy this file to .env and customize for your environment.
# Usage: cp .env.example .env
#
# The UAWOS daemon reads these variables at startup.
# Docker Compose also uses this file if present.
# ============================================================

# --- Authentication ---
# CRITICAL: Change this for any non-development deployment.
# The daemon will warn on startup if the default token is used.
UAWOS_SECURE_TOKEN=uawos-secure-token-change-me

# --- PostgreSQL (Required) ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5435
POSTGRES_DB=marquez
POSTGRES_USER=marquez
POSTGRES_PASSWORD=change-me-in-production

# --- Qdrant Vector Database (Required) ---
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# --- Ollama Local LLM Gateway (Recommended) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# --- Marquez Data Lineage (Optional) ---
MARQUEZ_HOST=127.0.0.1
MARQUEZ_PORT=5000

# --- Apache Superset BI (Optional) ---
SUPERSET_HOST=127.0.0.1
SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=change-me-in-production

# --- Dependency-Track SBOM (Optional) ---
DTRACK_HOST=127.0.0.1
DTRACK_PORT=8081
DTRACK_UI_HOST=127.0.0.1
DTRACK_UI_PORT=8085

# --- OPA Policy Engine (Optional) ---
OPA_HOST=127.0.0.1
OPA_PORT=8181

# --- OpenFGA Authorization (Optional) ---
OPENFGA_HOST=127.0.0.1
OPENFGA_PORT=8083

# --- OpenMetadata Catalog (Optional) ---
OPENMETADATA_HOST=127.0.0.1
OPENMETADATA_PORT=8585

# --- ClickHouse Telemetry (Optional) ---
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123

# --- Langfuse Telemetry (Optional) ---
TELEMETRY_HOST=127.0.0.1
TELEMETRY_PORT=3000

# --- Alertmanager Alarms (Optional) ---
ALARM_HOST=127.0.0.1
ALARM_PORT=9093

# --- OpenHands Sandbox (Optional) ---
SANDBOX_HOST=127.0.0.1
SANDBOX_PORT=5001

# --- Neo4j Graph Database (Optional) ---
NEO4J_HOST=127.0.0.1
NEO4J_PORT_1=7687
NEO4J_PORT_2=7474
